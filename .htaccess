Options -Indexes
RewriteEngine On
RewriteRule ^api/v1/products/([^/]+)/latest-release/?$ api/v1/products/latest-release.php?product_id=$1 [QSA,L]
RewriteRule ^api/v1/licenses/(activate|validate|deactivate|check-updates)/?$ api/v1/licenses/$1.php [QSA,L]
<FilesMatch "^(config\.php|config-example\.php)$">
  Require all denied
</FilesMatch>
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>
